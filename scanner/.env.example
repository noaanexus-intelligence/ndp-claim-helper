# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง (ห้าม commit .env ขึ้น git)
# ---- การเชื่อมต่อฐานข้อมูล HOSxP (MySQL/MariaDB) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=readonly_user
DB_PASSWORD=
DB_NAME=hos

# แนะนำอย่างยิ่ง: ใช้ user ที่มีสิทธิ์ SELECT อย่างเดียวก่อน (READ-ONLY)
# ถ้าต้องการเปิดโหมดแก้ไขตารางตั้งค่า ให้ตั้งเป็น true (ค่าเริ่มต้น false = อ่านอย่างเดียว)
ALLOW_WRITES=false

# พอร์ตที่เปิดหน้าเว็บในเครื่อง (เปิด http://localhost:<PORT>)
PORT=4300

# ผูกเฉพาะ localhost เพื่อความปลอดภัย (อย่าเปิดออกเน็ต)
BIND=127.0.0.1
